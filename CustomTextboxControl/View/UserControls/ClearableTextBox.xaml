<UserControl x:Class="CustomTextboxControl.View.UserControls.ClearableTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CustomTextboxControl.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="250"
			 FontSize="22">
	<Grid Background="AliceBlue">
		<TextBox	 Name="txtInput"
					 VerticalContentAlignment="Center"
					 HorizontalContentAlignment="Center"
					 Background="Transparent"
					 TextChanged="txtInput_TextChanged"
					 KeyDown="txtInput_KeyDown"
					/>
		<TextBlock	Name="tbPlaceHolder" Text="Placeholder"
					FontWeight="Light" Foreground="DarkGray"
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					Panel.ZIndex="-1"
					/>
		<Button		Name="btnClear"
					Width="40"
					HorizontalAlignment="Right"
					VerticalAlignment="Center"
					Content="⮾" FontSize="24"
					Foreground="DarkGray"
					Background="Transparent"
					BorderThickness="0"
					IsTabStop="False"
					Click="btnClear_Click"
					/>
	</Grid>
</UserControl>
